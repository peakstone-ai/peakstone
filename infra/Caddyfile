# Peakstone reverse proxy + automatic HTTPS.
#
# {$PEAKSTONE_DOMAIN} is set in the environment (see docker-compose.yml / .env). Caddy provisions
# and renews a Let's Encrypt certificate for it automatically — no certbot, no cron.
#
# Defaults to `localhost`, which makes Caddy mint a local self-signed cert so the whole stack also
# works on your laptop with no public DNS. For the real deploy set PEAKSTONE_DOMAIN=peakstone.ai
# (DNS A record -> the server's public IP, ports 80 + 443 reachable) and Caddy does the rest.
# Canonical host: redirect www -> the bare apex (one URL for cookies/SEO/links). Needs a DNS record
# for www.<domain> too (A -> the server, or CNAME -> the apex). Harmless on the localhost smoke test.
www.{$PEAKSTONE_DOMAIN:localhost} {
	redir https://{$PEAKSTONE_DOMAIN:localhost}{uri} permanent
}

{$PEAKSTONE_DOMAIN:localhost} {
	encode zstd gzip
	# The API lives under /api/* (external clients: the TUI/CLI, submissions, `peakstone login`).
	# handle_path strips the /api prefix, so /api/leaderboard -> api:8000/leaderboard.
	handle_path /api/* {
		reverse_proxy api:8000
	}
	# Everything else is the website (the Next.js leaderboard / model pages / run explorer).
	handle {
		reverse_proxy web:3000
	}
}
