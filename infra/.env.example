# Copy to infra/.env and fill in for a production deploy. docker compose reads it automatically.

# The public domain Caddy provisions a TLS cert for. DNS A record -> this server's public IP,
# and ports 80 + 443 must be reachable. Use `localhost` for a local self-signed smoke test.
PEAKSTONE_DOMAIN=peakstone.ai

# Postgres credentials. CHANGE THE PASSWORD before exposing the server.
POSTGRES_USER=peakstone
POSTGRES_PASSWORD=change-me-to-something-strong
POSTGRES_DB=peakstone
