# Copy to infra/.env and fill in for a production deploy. docker compose reads it automatically.

# The public domain Caddy provisions a TLS cert for. DNS A record -> this server's public IP,
# and ports 80 + 443 must be reachable. Use `localhost` for a local self-signed smoke test.
PEAKSTONE_DOMAIN=peakstone.ai

# Postgres credentials. CHANGE THE PASSWORD before exposing the server.
POSTGRES_USER=peakstone
POSTGRES_PASSWORD=change-me-to-something-strong
POSTGRES_DB=peakstone

# The suite the default (held-out) leaderboard scopes to — bundles must carry this exact
# suite@version for the headline to be apples-to-apples. Matches the engine's level-manifest
# version (peakstone/engine/levels.toml). Bump both together when cutting a new official suite.
PEAKSTONE_OFFICIAL_SUITE=level-standard@2026.06

# Operator key(s) trusted to seed the ranked board — comma-separated ed25519 pubkeys. A bundle signed
# by one ingests as runner-verified (ranks); everyone else is self-reported (provisional) until
# reproduced. WITHOUT THIS THE RANKED HELD-OUT BOARD IS EMPTY. Get your seed machine's pubkey with:
#   python -c "from peakstone.engine import keys; print(keys.load_or_create_keypair()[1])"
PEAKSTONE_TRUSTED_PUBKEYS=

# GitHub OAuth app credentials for `peakstone login` / account binding (leave blank to disable it).
# Create an OAuth app at https://github.com/settings/developers; register the CLI loopback callback
# http://127.0.0.1:53682/callback (peakstone login's default port).
PEAKSTONE_GITHUB_CLIENT_ID=
PEAKSTONE_GITHUB_CLIENT_SECRET=

# Community-verified provenance bar: an account must be this many days old before its reproductions
# count toward promoting a run. Two just-minted OAuth accounts agreeing is not verification —
# the age bar makes self-verification slow and deliberate. 0 disables (dev default); set it in prod.
PEAKSTONE_COMMUNITY_MIN_ACCOUNT_AGE_DAYS=7

# Client-version policy served at /version (both optional). LATEST = the newest client you've published
# (the dashboard nudges users to upgrade to it); blank = the server's own version. MIN = the oldest
# client allowed to submit (older ones get 426); blank = 0.1.0. Bump LATEST each time you release a
# client; bump MIN only when old clients would produce incompatible bundles.
PEAKSTONE_CLIENT_LATEST=
PEAKSTONE_CLIENT_MIN=
