# Permissively-licensed imports are committed so `standard@2026.07` is self-contained:
#   humaneval (MIT) in full; a bigcodebench (Apache-2.0) slice for the standard/quick axes
#   (the full 1k+ set regenerates via peakstone.engine.importers.bigcodebench for deep/max).
/challenges/bigcodebench/*
!/challenges/bigcodebench/SOURCE.md
!/challenges/bigcodebench/bcb-000*
!/challenges/bigcodebench/bcb-001*
!/challenges/bigcodebench/bcb-002*
!/challenges/bigcodebench/bcb-003*
!/challenges/bigcodebench/bcb-004*
# Copyright-encumbered sets are NEVER committed — Codeforces/LiveCodeBench statements are
# platform-copyrighted, AIME is MAA-copyrighted, SWE-bench mixes upstream repo licenses. Use them
# only as PRIVATE challenges (you accept the upstream terms); regenerate via their importers.
/challenges/livecodebench/
/challenges/codeforces/
/challenges/aime/
/challenges/swebench/

# Private challenges (vision Idea 2: Private Test Crafter / commit-and-reveal). A private
# challenge must NEVER be committed — publishing it defeats its held-out purpose; only a hash
# commitment (and, later, an explicit reveal) is meant to leave the box. Provisional guard placed
# BEFORE that feature is built; reconfirm the path matches when implementing it (see vision.md, Idea 2).
/challenges/private/

# Claude Code per-machine local settings (permission allowlist etc.) — keep out of the repo
.claude/settings.local.json
/gateway.log

# local security review notes — must never be published
RELEASE-REVIEW.md
